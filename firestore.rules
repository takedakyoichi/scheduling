rules_version = '2';

// 調整くん Firestore セキュリティルール
// 認可モデル：ホスト操作は events.ownerUids（Googleログインのuid）に紐づく。
// 参加者は匿名のまま閲覧・投票のみ可能。
service cloud.firestore {
  match /databases/{database}/documents {

    // 個人のブックマーク（マイイベント一覧）：本人のみ読み書き可
    match /users/{uid}/events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /events/{eventId} {
      // 閲覧は誰でも可（参加者がリアルタイム購読するため必須）
      allow read: if true;

      // 作成：ログイン必須。自分自身を唯一のownerとして登録すること。
      allow create: if request.auth != null
        && request.resource.data.ownerUids is list
        && request.resource.data.ownerUids.size() == 1
        && request.auth.uid in request.resource.data.ownerUids;

      // クライアントからの削除は不可
      allow delete: if false;

      // 更新：ホスト本人 / 参加者の投票 / 支払済みトグル / 旧イベントの移行クレーム
      allow update: if isOwner() || isParticipantWrite() || isPaidToggle() || isLegacyClaim();
    }

    // ホスト本人（ownerUidsに含まれるログインユーザー）
    function isOwner() {
      return request.auth != null
        && resource.data.ownerUids is list
        && request.auth.uid in resource.data.ownerUids;
    }

    // 参加者：participants / participantOrder のみ変更可（ホスト専用項目は触れない）
    function isParticipantWrite() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['participants', 'participantOrder']);
    }

    // 参加者の「支払済み」トグル：settle.paid のみ変更可（金額等の精算データは不変）
    function isPaidToggle() {
      return 'settle' in resource.data
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['settle'])
        && request.resource.data.settle.diff(resource.data.settle).affectedKeys().hasOnly(['paid']);
    }

    // 旧イベント（ownerUids未設定）をログインユーザーがクレーム（移行用・ownerUidsの新規付与のみ）
    function isLegacyClaim() {
      return request.auth != null
        && !('ownerUids' in resource.data)
        && request.resource.data.ownerUids == [request.auth.uid]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerUids']);
    }
  }
}
